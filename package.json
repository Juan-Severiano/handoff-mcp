{
  "name": "context-hub-mcp",
  "version": "1.0.0",
  "description": "MCP Server for shared project context across multiple LLMs (Claude, Gemini, Copilot)",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outfile dist/index.js --target bun",
    "inspect": "npx @modelcontextprotocol/inspector bun src/index.ts"
  },
  "bin": {
    "context-hub-mcp": "dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "overrides": {
    "@types/node": "^20.17.0"
  },
  "keywords": [
    "mcp",
    "context",
    "llm",
    "claude",
    "gemini",
    "copilot"
  ],
  "license": "MIT"
}